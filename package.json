{
    "name": "pesto-bot",
    "version": "0.2.12",
    "description": "A simple discord bot for the pesties",
    "main": "app/index.ts",
    "type": "module",
    "scripts": {
        "start": "NODE_ENV=production bun .",
        "dev": "NODE_ENV=development MAINTENANCE=true bun .",
